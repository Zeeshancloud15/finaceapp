pipeline {

```
agent any

tools {
    nodejs 'NodeJS'
}

environment {
    APP_NAME = "finaceapp"
    DOCKER_IMAGE = "zeeshancloud15/finaceapp"
    DOCKER_TAG = "${BUILD_NUMBER}"
    SONARQUBE_ENV = "sonarqube"
    KUBE_NAMESPACE = "finance"
}

stages {

    stage('Checkout') {
        steps {
            echo "Cloning Source Code"
            checkout scm
        }
    }

    stage('Install Dependencies') {
        steps {
            sh 'npm install'
        }
    }

    stage('Unit Test') {
        steps {
            sh 'npm test'
        }
    }

    stage('SonarQube Scan') {
        steps {
            withSonarQubeEnv("${SONARQUBE_ENV}") {
                sh '''
                sonar-scanner \
                -Dsonar.projectKey=finaceapp \
                -Dsonar.projectName=finaceapp \
                -Dsonar.sources=. \
                -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info
                '''
            }
        }
    }

    stage('Quality Gate') {
        steps {
            timeout(time: 10, unit: 'MINUTES') {
                waitForQualityGate abortPipeline: true
            }
        }
    }

    stage('Docker Build') {
        steps {
            sh '''
            docker build \
            -t ${DOCKER_IMAGE}:${DOCKER_TAG} \
            -t ${DOCKER_IMAGE}:latest .
            '''
        }
    }

    stage('Container Smoke Test') {
        steps {
            sh '''
            docker rm -f finance-test || true

            docker run -d \
            --name finance-test \
            -p 8080:8080 \
            ${DOCKER_IMAGE}:${DOCKER_TAG}

            sleep 15

            curl -f http://localhost:8080/health

            docker rm -f finance-test
            '''
        }
    }

    stage('Docker Hub Login') {
        steps {
            withCredentials([
                usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )
            ]) {
                sh '''
                echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                '''
            }
        }
    }

    stage('Push Docker Image') {
        steps {
            sh '''
            docker push ${DOCKER_IMAGE}:${DOCKER_TAG}
            docker push ${DOCKER_IMAGE}:latest
            '''
        }
    }

    stage('Deploy Namespace') {
        steps {
            sh '''
            kubectl apply -f kubernetes/namespace.yaml
            '''
        }
    }

    stage('Deploy Application') {
        steps {
            sh '''
            kubectl apply -f kubernetes/deployment.yaml
            kubectl apply -f kubernetes/service.yaml
            '''
        }
    }

    stage('Verify Deployment') {
        steps {
            sh '''
            kubectl rollout status deployment/finaceapp -n finance --timeout=180s

            kubectl get pods -n finance

            kubectl get svc -n finance
            '''
        }
    }
}

post {

    success {
        echo "Build Successful"
    }

    failure {
        echo "Build Failed"
    }

    always {
        sh 'docker logout || true'
    }
}
```

}
