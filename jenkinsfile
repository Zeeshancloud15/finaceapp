pipeline {

    agent any

    options {
        skipDefaultCheckout(true)
        timestamps()
    }

    environment {

        // Git
        GIT_REPO   = 'https://github.com/Zeeshancloud15/finaceapp.git'
        GIT_BRANCH = 'main'

        // Docker Hub
        IMAGE_NAME = 'zeeshancloud15/finaceapp'
        IMAGE_TAG  = "${BUILD_NUMBER}"

        // Nexus
        NEXUS_URL  = 'http://44.204.234.177:8081'
        NEXUS_REPO = 'node-artifacts'

        // Kubernetes
        K8S_MASTER = '52.207.237.43'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: "${GIT_BRANCH}",
                    url: "${GIT_REPO}"
            }
        }

        stage('Verify Environment') {
            steps {
                sh '''
                echo "===== Workspace ====="
                pwd
                ls -la

                echo "===== Node ====="
                node -v
                npm -v

                echo "===== Docker ====="
                docker --version
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'npm test'
            }
        }

        stage('SonarQube Scan') {
            steps {
                script {

                    def scannerHome = tool 'sonar-scanner'

                    withSonarQubeEnv('sonar-fin') {

                        sh """
                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectKey=finaceapp \
                        -Dsonar.projectName=finaceapp \
                        -Dsonar.sources=. \
                        -Dsonar.exclusions=node_modules/** \
                        -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Package Artifact') {
            steps {
                sh """
                tar \
                --warning=no-file-changed \
                --exclude=node_modules \
                --exclude=.git \
                -czf /tmp/finance-app-${BUILD_NUMBER}.tar.gz .

                mv /tmp/finance-app-${BUILD_NUMBER}.tar.gz .
                """
            }
        }

        stage('Upload Artifact to Nexus') {
            steps {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'nexus-creds',
                        usernameVariable: 'NEXUS_USER',
                        passwordVariable: 'NEXUS_PASS'
                    )
                ]) {

                    sh """
                    curl -v \
                    -u ${NEXUS_USER}:${NEXUS_PASS} \
                    --upload-file finance-app-${BUILD_NUMBER}.tar.gz \
                    ${NEXUS_URL}/repository/${NEXUS_REPO}/finance-app-${BUILD_NUMBER}.tar.gz
                    """
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh """
                docker build \
                -t ${IMAGE_NAME}:${IMAGE_TAG} \
                -t ${IMAGE_NAME}:latest .
                """
            }
        }

        stage('Docker Login') {
            steps {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {

                    sh '''
                    echo "$DOCKER_PASS" | docker login \
                    -u "$DOCKER_USER" \
                    --password-stdin
                    '''
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                sh """
                docker push ${IMAGE_NAME}:${IMAGE_TAG}
                docker push ${IMAGE_NAME}:latest
                """
            }
        }

        stage('Deploy Kubernetes') {
            steps {

                sshagent(['ssh-cred']) {

                    sh """
                    ssh -o StrictHostKeyChecking=no ubuntu@${K8S_MASTER} 'mkdir -p /home/ubuntu/k8s'
                    """

                    sh """
                    scp -o StrictHostKeyChecking=no kubernetes/*.yaml \
                    ubuntu@${K8S_MASTER}:/home/ubuntu/k8s/
                    """

                    sh """
                    ssh -o StrictHostKeyChecking=no ubuntu@${K8S_MASTER} '
                        kubectl apply -f /home/ubuntu/k8s/namespace.yaml
                        kubectl apply -f /home/ubuntu/k8s/deployment.yaml
                        kubectl apply -f /home/ubuntu/k8s/service.yaml

                        kubectl set image deployment/finance-app \
                        finance-app=${IMAGE_NAME}:${IMAGE_TAG} \
                        -n finance

                        kubectl rollout status deployment/finance-app \
                        -n finance --timeout=180s

                        kubectl get pods -n finance
                        kubectl get svc -n finance
                    '
                    """
                }
            }
        }
    }

    post {

        success {
            echo "Pipeline Completed Successfully"
        }

        failure {
            echo "Pipeline Failed"
        }

        always {
            sh 'docker logout || true'
            cleanWs()
        }
    }
}
