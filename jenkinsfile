pipeline {

```
agent any

environment {
    DOCKER_IMAGE = "zeeshancloud15/finaceapp"
    BUILD_TAG = "${BUILD_NUMBER}"
    K8S_MASTER = "54.227.217.130"
}

stages {

    stage('Checkout') {
        steps {
            echo 'Checkout Source Code'
            checkout scm
        }
    }

    stage('Verify Environment') {
        steps {
            sh '''
            pwd
            ls -la
            node -v
            npm -v
            docker --version
            '''
        }
    }

    stage('Install Dependencies') {
        steps {
            sh 'npm ci'
        }
    }

    stage('Run Tests') {
        steps {
            sh 'npm test'
        }
    }

    stage('SonarQube Scan') {
        steps {
            script {

                def scannerHome = tool 'sonar-scanner'

                withSonarQubeEnv('sonar-fin') {

                    sh """
                    ${scannerHome}/bin/sonar-scanner \
                    -Dsonar.projectKey=finaceapp \
                    -Dsonar.projectName=finaceapp \
                    -Dsonar.sources=. \
                    -Dsonar.exclusions=node_modules/**,coverage/** \
                    -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info
                    """
                }
            }
        }
    }

    stage('Quality Gate') {
        steps {
            timeout(time: 5, unit: 'MINUTES') {
                waitForQualityGate abortPipeline: true
            }
        }
    }

    stage('Docker Build') {
        steps {
            sh """
            docker build \
            -t ${DOCKER_IMAGE}:${BUILD_TAG} \
            -t ${DOCKER_IMAGE}:latest .
            """
        }
    }

    stage('Docker Login') {
        steps {
            withCredentials([
                usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )
            ]) {

                sh '''
                echo "$DOCKER_PASS" | docker login \
                -u "$DOCKER_USER" \
                --password-stdin
                '''
            }
        }
    }

    stage('Push Docker Image') {
        steps {
            sh """
            docker push ${DOCKER_IMAGE}:${BUILD_TAG}
            docker push ${DOCKER_IMAGE}:latest
            """
        }
    }

    stage('Copy Kubernetes Manifests') {
        steps {

            sshagent(['k8s-master-key']) {

                sh """
                ssh -o StrictHostKeyChecking=no ubuntu@${K8S_MASTER} '
                    mkdir -p /home/ubuntu/k8s
                '

                scp -o StrictHostKeyChecking=no \
                kubernetes/*.yaml \
                ubuntu@${K8S_MASTER}:/home/ubuntu/k8s/
                """
            }
        }
    }

    stage('Deploy Kubernetes') {
        steps {

            sshagent(['k8s-master-key']) {

                sh """
                ssh -o StrictHostKeyChecking=no ubuntu@${K8S_MASTER} '

                kubectl apply -f /home/ubuntu/k8s/namespace.yaml
                kubectl apply -f /home/ubuntu/k8s/deployment.yaml
                kubectl apply -f /home/ubuntu/k8s/service.yaml

                '
                """
            }
        }
    }

    stage('Verify Deployment') {
        steps {

            sshagent(['k8s-master-key']) {

                sh """
                ssh -o StrictHostKeyChecking=no ubuntu@${K8S_MASTER} '

                kubectl rollout status deployment/finance-app -n finance

                echo "========== PODS =========="
                kubectl get pods -n finance -o wide

                echo "========== SERVICES =========="
                kubectl get svc -n finance

                '

                """
            }
        }
    }
}

post {

    success {
        echo 'Build Successful'
    }

    failure {
        echo 'Build Failed'
    }

    always {

        sh '''
        docker logout || true
        '''

        cleanWs()
    }
}
```

}
