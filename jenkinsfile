pipeline {

    agent any

    tools {
        nodejs 'NodeJS'
    }

    environment {
        APP_NAME       = 'finaceapp'
        DOCKER_IMAGE   = 'zeeshancloud15/finaceapp'
        SONARQUBE_ENV  = 'sonar-fin'
        KUBE_NAMESPACE = 'finance'
        BUILD_TAG_NAME = "${BUILD_NUMBER}"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
                git branch: 'main',
                    url: 'https://github.com/Zeeshancloud15/finaceapp.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                    npm install
                '''
            }
        }

        stage('Run Tests') {
            steps {
                sh '''
                    npm test
                '''
            }
        }

        stage('SonarQube Scan') {
            steps {
                withSonarQubeEnv("${SONARQUBE_ENV}") {
                    sh '''
                        sonar-scanner \
                        -Dsonar.projectKey=finaceapp \
                        -Dsonar.projectName=finaceapp \
                        -Dsonar.sources=.
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh """
                    docker build \
                    -t ${DOCKER_IMAGE}:${BUILD_TAG_NAME} \
                    -t ${DOCKER_IMAGE}:latest .
                """
            }
        }

        stage('Container Verification') {
            steps {
                sh '''
                    docker rm -f finance-test || true

                    docker run -d \
                      --name finance-test \
                      -p 8080:8080 \
                      ${DOCKER_IMAGE}:${BUILD_TAG_NAME}

                    sleep 15

                    curl -f http://localhost:8080/health

                    docker rm -f finance-test || true
                '''
            }
        }

        stage('Docker Hub Login') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login \
                        -u "$DOCKER_USER" \
                        --password-stdin
                    '''
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                sh """
                    docker push ${DOCKER_IMAGE}:${BUILD_TAG_NAME}
                    docker push ${DOCKER_IMAGE}:latest
                """
            }
        }

        stage('Deploy Namespace') {
            steps {
                sh '''
                    kubectl apply -f kubernetes/namespace.yaml
                '''
            }
        }

        stage('Deploy Application') {
            steps {
                sh '''
                    kubectl apply -f kubernetes/deployment.yaml
                    kubectl apply -f kubernetes/service.yaml
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                    kubectl rollout status deployment/finaceapp \
                    -n finance --timeout=180s

                    kubectl get pods -n finance

                    kubectl get svc -n finance
                '''
            }
        }
    }

    post {

        success {
            echo 'Pipeline completed successfully.'
        }

        failure {
            echo 'Pipeline failed.'
        }

        always {
            sh 'docker logout || true'
        }
    }
}
